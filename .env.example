# Site URL (optional — defaults to toolbeltlogic.com in code)
SITE_URL=https://www.toolbeltlogic.com

# App store links (optional — update when listings go live)
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/us/app/tb-logic/id6783934469
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.ulatorcalc.app

# Support email — feedback form sends to support@toolbeltlogic.com
# Microsoft 365 (including email from GoDaddy):
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=support@toolbeltlogic.com
SMTP_PASS=your-mailbox-password
SMTP_FROM=support@toolbeltlogic.com
# If MFA is on, use a Microsoft 365 app password instead of your normal password.
# GoDaddy Workspace (non-M365) uses: SMTP_HOST=smtpout.secureserver.net
