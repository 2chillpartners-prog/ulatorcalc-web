# Site URL (optional — defaults to toolbeltlogic.com in code)
SITE_URL=https://www.toolbeltlogic.com

# Support email — sends feedback form submissions to support@toolbeltlogic.com
# GoDaddy / Microsoft 365 on toolbeltlogic.com:
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USER=support@toolbeltlogic.com
SMTP_PASS=your-mailbox-password
SMTP_FROM=support@toolbeltlogic.com
# If using Microsoft 365 instead: SMTP_HOST=smtp.office365.com, SMTP_PORT=587
